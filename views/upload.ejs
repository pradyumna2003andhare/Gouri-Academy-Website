<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Upload Material</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f4f6fb;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
        }

        .container {
            background: white;
            padding: 40px;
            border-radius: 12px;
            width: 400px;
            box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.1);
            text-align: center;
        }

        h1 {
            color: #233d91;
            margin-bottom: 25px;
        }

        input {
            width: 100%;
            padding: 12px;
            margin-top: 15px;
            border-radius: 8px;
            border: 1px solid #ccc;
            font-size: 16px;
        }

        button {
            margin-top: 25px;
            width: 100%;
            padding: 12px;
            border: none;
            border-radius: 8px;
            background-color: #233d91;
            color: white;
            font-size: 18px;
            cursor: pointer;
        }

        button:hover {
            background-color: #1b3177;
        }
    </style>
</head>

<body>

    <div class="container">

        <h1>Upload Study Material</h1>

        <form action="/upload" method="POST" enctype="multipart/form-data">

            <input type="text" name="title" placeholder="Material Title" required>

            <input type="file" name="material" required>

            <button type="submit">
                Upload Files
            </button>

        </form>

    </div>

</body>

</html>